FROM python:3.12-slim

ARG UID=1000
ARG GID=1000

# Create non-root user
RUN groupadd -g ${GID} app \
 && useradd -u ${UID} -g app -m app

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Environment for non-root tools
ENV HOME=/home/app
ENV UV_CACHE_DIR=/home/app/.cache/uv
ENV PATH=/home/app/.local/bin:$PATH

# Create required dirs and fix ownership
RUN mkdir -p /app /home/app/.cache \
 && chown -R app:app /app /home/app

WORKDIR /app

# Switch user BEFORE installing deps
USER app

# Copy entrypoint
COPY --chown=app:app scripts/entrypoint.sh /app/scripts/entrypoint.sh
RUN chmod +x /app/scripts/entrypoint.sh

EXPOSE 8000

ENTRYPOINT ["/app/scripts/entrypoint.sh"]
