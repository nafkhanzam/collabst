FROM node:20-slim

ARG UID=1000
ARG GID=1000

# Rename node user/group to app, set UID/GID, and home
RUN groupmod -n app node \
 && groupmod -g ${GID} app \
 && usermod -l app -d /home/app -m node \
 && usermod -u ${UID} -g ${GID} app \
 && chown -R app:app /home/app

ENV HOME=/home/app

WORKDIR /app

# Fix ownership
RUN chown -R app:app /app

# Switch user BEFORE npm install
USER app

# Copy entrypoint
COPY --chown=app:app scripts/entrypoint.sh /app/scripts/entrypoint.sh
RUN chmod +x /app/scripts/entrypoint.sh

EXPOSE 5173

ENTRYPOINT ["/app/scripts/entrypoint.sh"]
