# Runtime mode
ENVIRONMENT=production

# Port configuration
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
BACKEND_PORT=8000

# Public URLs
WEB_URL=https://collabst.example.com
VITE_API_URL=/api/v1
MINIO_URL=storage.collabst.example.com

# API and CORS
API_V1_STR=/api/v1
CORS_ORIGINS=https://collabst.example.com

# Storage
MINIO_SECURE=true
MINIO_PUBLIC_SECURE=true

# Security (required)
POSTGRES_PASSWORD=change-me
MINIO_ROOT_PASSWORD=change-me
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Feature flags
REGISTRATION_ENABLED=false

# Optional runtime tuning
UVICORN_WORKERS=4
